{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "meetly",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-30",
  "vars": {
    "ELEVENLABS_KEY": ""
  },
  "ai": {
    "binding": "AI"
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [{ "name": "CALL_ROOM", "class_name": "CallRoom" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["CallRoom"] }]
}
