{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    { "source": "/join", "destination": "/index.html" },
    { "source": "/join/", "destination": "/index.html" },
    { "source": "/MEETLY-:code", "destination": "/index.html" },
    { "source": "/MEETLY-:code/", "destination": "/index.html" }
  ]
}
