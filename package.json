{
  "name": "meetly",
  "version": "1.0.0",
  "description": "1:1 video calls on Cloudflare Workers with real-time translation (Whisper, m2m100, ElevenLabs).",
  "main": "index.js",
  "scripts": {
    "build:client": "esbuild client/app.jsx --bundle --minify --outfile=public/app.js --format=esm --jsx=automatic --jsx-import-source=react",
    "predev": "npm run build:client",
    "dev": "wrangler dev",
    "deploy": "npm run build:client && wrangler deploy",
    "types": "wrangler types"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "esbuild": "^0.25.12",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
